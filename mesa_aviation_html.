    name:"Cunningham Aviation \u2014 Falcon Field FBO",
    type:"FBO / Aviation Services",
    address:"4753 E Falcon Dr, Suite 1, Mesa, AZ 85215",
    status:"Operating",
    why:"The key FBO anchor at Falcon Field. It gives the Falcon Field sub-cluster a specific airport-services operator rather than only showing the airport itself.",
    confidence:"High",
    caveat:"Label as \u201CCunningham Aviation \u2014 Falcon Field FBO.\u201D It may be useful to note that it consolidated the former Avflight Mesa operation, but do not overcomplicate the map label.",
    primary:"https://www.paragonaviationgroup.com/cunningham-aviation-acquires-assets-of-avflight-mesa-corporation/",
    news:"https://www.ainonline.com/aviation-news/2025-08-20/fbo-consolidates-arizonas-falcon-field",
    maps:"https://www.google.com/maps/search/?api=1&query=Cunningham%20Aviation%204753%20E%20Falcon%20Dr%20Suite%201%20Mesa%20AZ%2085215"
  }
];

const byId = id => DATA.find(d => d.id === Number(id));
const esc = s => String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
const host = u => { try { return new URL(u).hostname.replace(/^www\./,""); } catch(e){ return u; } };

function shortNews(u){
  const h = host(u);
  if(h.indexOf("linkedin")>-1) return "LinkedIn announcement";
  if(h.indexOf("faa.gov")>-1) return "FAA airport record";
  return h;
}

function renderCard(d){
  const newsRow = d.news ? `
    <a href="${esc(d.news)}" target="_blank" rel="noopener noreferrer">
      <span class="lk-ico">&#128240;</span>
      <span class="lk-txt">Recent / News source<small>${esc(shortNews(d.news))}</small></span>
    </a>` : "";

  return `
    <div class="card-head">
      <div class="card-num">${d.id}</div>
      <div>
        <h2>${esc(d.name)}</h2>
        <span class="card-type">${esc(d.type)}</span>
      </div>
    </div>

    <div class="badges">
      <span class="badge status">Status: ${esc(d.status)}</span>
      <span class="badge conf">Confidence: ${esc(d.confidence)}</span>
    </div>

    <div class="row"><span class="k">Address</span><span class="v">${esc(d.address)}</span></div>
    <div class="row"><span class="k">Why it matters</span><span class="v">${esc(d.why)}</span></div>

    <div class="caveat">
      <span class="k">Caveat / verification note</span>
      ${esc(d.caveat)}
    </div>

    <div class="links">
      <a href="${esc(d.primary)}" target="_blank" rel="noopener noreferrer">
        <span class="lk-ico">&#128279;</span>
        <span class="lk-txt">Primary source<small>${esc(host(d.primary))}</small></span>
      </a>
      ${newsRow}
      <a href="${esc(d.maps)}" target="_blank" rel="noopener noreferrer">
        <span class="lk-ico">&#128205;</span>
        <span class="lk-txt">Open in Google Maps<small>Verify pin position</small></span>
      </a>
    </div>
  `;
}

const panelInner = document.getElementById("panelInner");
const markers = Array.from(document.querySelectorAll(".marker"));
const refGrid = document.getElementById("refGrid");

function select(id){
  const d = byId(id);
  if(!d) return;
  panelInner.innerHTML = renderCard(d);
  markers.forEach(m => m.classList.toggle("active", m.dataset.id === String(id)));
  document.querySelectorAll(".ref-item").forEach(r => r.classList.toggle("active", r.dataset.id === String(id)));
}

// build reference list in fixed numeric order
[...DATA].sort((a,b)=>a.id-b.id).forEach(d => {
  const div = document.createElement("div");
  div.className = "ref-item";
  div.dataset.id = d.id;
  div.setAttribute("role","button");
  div.setAttribute("tabindex","0");
  div.innerHTML = `<span class="ref-num">${d.id}</span><span class="ref-name">${esc(d.name)}<small>${esc(d.type)}</small></span>`;
  div.addEventListener("click", () => select(d.id));
  div.addEventListener("keydown", e => { if(e.key==="Enter"||e.key===" "){ e.preventDefault(); select(d.id);} });
  refGrid.appendChild(div);
});

// wire markers
markers.forEach(m => {
  m.setAttribute("role","button");
  m.setAttribute("tabindex","0");
  m.setAttribute("aria-label","Marker " + m.dataset.id);
  m.addEventListener("click", () => select(m.dataset.id));
  m.addEventListener("keydown", e => { if(e.key==="Enter"||e.key===" "){ e.preventDefault(); select(m.dataset.id);} });
});

// open with the primary anchor selected
select(1);
</script>
</body>
</html>
